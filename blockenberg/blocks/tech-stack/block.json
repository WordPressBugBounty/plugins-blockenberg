            {
              "id": "ti7",
              "name": "Redis",
              "imageUrl": "",
              "imageId": 0,
              "url": "",
              "linkTarget": false,
              "description": "Cache",
              "proficiency": 3
            },
            {
              "id": "ti8",
              "name": "Docker",
              "imageUrl": "",
              "imageId": 0,
              "url": "",
