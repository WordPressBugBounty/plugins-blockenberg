            "type": "object",
            "default": {}
        },
        "subtextTypo": {
            "type": "object",
            "default": {}
        },
        "nameTypo": {
            "type": "object",
            "default": {}
        },
        "priceTypo": {
            "type": "object",
            "default": {}
        },
        "descTypo": {
            "type": "object",
            "default": {}
        },
        "featureTypo": {
            "type": "object",
            "default": {}
        }
    }
