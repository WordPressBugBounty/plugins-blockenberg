        "showDayTabs": {
            "type": "boolean",
            "default": true
        },
        "showSpeakerAvatar": {
            "type": "boolean",
            "default": true
        },
        "showRoom": {
            "type": "boolean",
            "default": true
        },
        "showDuration": {
            "type": "boolean",
            "default": true
        },
        "showTags": {
            "type": "boolean",
            "default": true
        },
        "showSpeakerRole": {
            "type": "boolean",
            "default": true
        },
        "showSpeakerCompany": {
            "type": "boolean",
            "default": true
        },
        "sessionStyle": {
            "type": "string",
