{
    "apiVersion": 3,
    "name": "blockenberg/highlight-reel",
    "title": "Highlight Reel",
    "category": "bkbg-content",
    "icon": "star-filled",
    "description": "Grid of curated highlight cards — ideal for showcasing achievements, features, event moments, or key stats with icons and descriptions.",
    "textdomain": "blockenberg",
    "editorScript": "bkbg-highlight-reel-editor",
    "style": "bkbg-highlight-reel-style",
    "attributes": {
        "title": {
            "type": "string",
            "default": "Session Highlights"
        },
        "showTitle": {
            "type": "boolean",
            "default": true
