        "showIcon": {
            "type": "boolean",
            "default": true
        },
        "showTag": {
            "type": "boolean",
            "default": true
        },
        "showDesc": {
            "type": "boolean",
            "default": true
        },
        "iconSize": {
            "type": "number",
            "default": 36
