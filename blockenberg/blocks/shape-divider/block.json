{
    "apiVersion": 3,
    "name": "blockenberg/shape-divider",
    "title": "Shape Divider",
    "category": "bkbg-layout",
    "icon": "chart-area",
    "description": "SVG shape dividers — wave, curve, triangle, tilt, zigzag — to create seamless section transitions.",
    "keywords": [
        "shape",
        "divider",
        "wave",
        "separator",
        "svg",
        "section"
    ],
    "textdomain": "blockenberg",
    "editorScript": "bkbg-shape-divider-editor",
    "editorStyle": "bkbg-shape-divider-style",
    "style": "bkbg-shape-divider-style",
    "viewScript": "bkbg-shape-divider-frontend",
    "supports": {
        "html": false,
        "anchor": true,
        "className": true,
        "align": [
            "wide",
            "full"
        ]
    },
    "attributes": {
        "shape": {
            "type": "string",
            "default": "wave"
        },
        "position": {
            "type": "string",
            "default": "bottom"
        },
        "height": {
            "type": "number",
            "default": 80
        },
        "color": {
            "type": "string",
            "default": "#ffffff"
        },
        "bgColor": {
            "type": "string",
            "default": ""
        },
        "flipHorizontal": {
            "type": "boolean",
            "default": false
        },
        "flipVertical": {
            "type": "boolean",
            "default": false
        },
        "width": {
            "type": "number",
            "default": 100
        },
        "animate": {
            "type": "boolean",
            "default": false
        },
        "animationSpeed": {
            "type": "number",
            "default": 8
        },
        "layers": {
            "type": "number",
            "default": 1
        },
        "layer2Color": {
            "type": "string",
            "default": "rgba(255,255,255,0.4)"
        },
        "layer2Offset": {
            "type": "number",
            "default": 12
        },
        "zIndex": {
            "type": "number",
            "default": 1
        }
    }
}
